# ===========================================
# Matrimony Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---------- Database (MySQL) ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=matrimony_db
DB_USER=root
DB_PASSWORD=your_db_password_here

# ---------- JWT Authentication ----------
JWT_SECRET=skc_infotech_matchb

# ---------- App Settings ----------
APP_URL=http://your-vps-ip:8050

# ---------- Exotel (Call API) ----------
EXOTEL_SID=your_exotel_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SUBDOMAIN=your_exotel_subdomain
EXOTEL_VIRTUAL_NUMBER=your_exotel_virtual_number

# ---------- Cloudinary (Image Upload) ----------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ---------- Credit System ----------
HAS_CREDIT_DEDUCTION_TRIGGER=false
